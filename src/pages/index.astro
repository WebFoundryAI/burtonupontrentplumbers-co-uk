---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroWithLeadForm from '../components/HeroWithLeadForm.astro';
import { BRAND } from '../data/brand';
import { SERVICES } from '../data/services';
import { LOCATIONS } from '../data/locations';
import { getHomepageSchema } from '../utils/schema';
import { HOMEPAGE_FAQS } from '../data/faqs';

const title = `Blocked Drains Manchester | 24/7 Drain Unblocking & Emergency Repairs`;
const description = `Blocked drains in Manchester fixed fast. Local engineers, fixed pricing, and 24/7 emergency drainage response. Call ${BRAND.phoneFormatted} or request a quote online.`;
---

<BaseLayout title={title} description={description} canonical="/" schema={getHomepageSchema()}>
  <HeroWithLeadForm
    title="Blocked Drains Manchester — fast fixes, fair pricing"
    description="Get same-day drainage support from experienced local engineers. We clear blocked sinks, toilets, and outside drains with no hidden extras."
    formId="home-lead-form"
    source="homepage"
  />

  <section class="section section--tight">
    <div class="container">
      <h2>Popular drainage services</h2>
      <div class="grid grid--3">
        {SERVICES.map((service) => (
          <article class="card">
            <p class="card__icon text-3xl mb-2" aria-hidden="true">{service.icon}</p>
            <h3 class="card__title">{service.name}</h3>
            <p class="card__meta">{service.shortLabel}</p>
            <a href={`/services/${service.slug}/`} class="btn btn--secondary mt-4">View service</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container">
      <h2>How it works</h2>
      <div class="grid grid--3">
        <article class="card"><h3>1) Tell us the issue</h3><p>Share your postcode and drainage problem so we can prioritise correctly.</p></article>
        <article class="card"><h3>2) Engineer attends fast</h3><p>Local engineers aim for rapid arrival and complete diagnostics on site.</p></article>
        <article class="card"><h3>3) Clear, fix, and report</h3><p>We resolve the problem and explain the root cause and prevention steps.</p></article>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <h2>Why choose us</h2>
      <ul class="grid grid--2">
        <li class="card">No call-out charge and fixed pricing before work starts.</li>
        <li class="card">Fully insured engineers with modern diagnostic equipment.</li>
        <li class="card">Domestic and commercial drainage specialists.</li>
        <li class="card">Emergency response available day and night.</li>
      </ul>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container">
      <h2>Coverage near Manchester</h2>
      <p>We cover Greater Manchester locations including:</p>
      <div class="grid grid--3">
        {LOCATIONS.map((location) => (
          <a class="card" href={`/locations/${location.slug}/`}>Blocked drains in {location.name}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <h2>Frequently asked questions</h2>
      <div class="accordion">
        {HOMEPAGE_FAQS.slice(0, 6).map((faq, i) => (
          <details class="accordion__item" open={i === 0}>
            <summary class="accordion__trigger">{faq.question}</summary>
            <div class="accordion__panel"><p>{faq.answer}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-slate-900 text-white">
    <div class="container text-center">
      <h2>Need urgent drainage help?</h2>
      <p>Call now for a rapid response anywhere in {BRAND.serviceAreaLabel}.</p>
      <a class="btn btn--primary" href={`tel:${BRAND.phone}`}>Call {BRAND.phoneFormatted}</a>
    </div>
  </section>
</BaseLayout>
