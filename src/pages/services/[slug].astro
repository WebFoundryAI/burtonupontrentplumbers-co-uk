---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroWithLeadForm from '../../components/HeroWithLeadForm.astro';
import { SERVICES, getServiceBySlug, getRelatedServices } from '../../data/services';
import { LOCATIONS } from '../../data/locations';
import { BRAND } from '../../data/brand';
import { getBreadcrumbSchema, getServicePageSchema } from '../../utils/schema';

export async function getStaticPaths() {
  return SERVICES.map((service) => ({ params: { slug: service.slug } }));
}

const { slug } = Astro.params;
const service = getServiceBySlug(slug || '');
if (!service) return Astro.redirect('/services/');

const title = `${service.name} Manchester | Fast Local Drainage Service`;
const description = `${service.description} Call ${BRAND.phoneFormatted} for rapid ${service.name.toLowerCase()} support in Manchester and nearby areas.`;

const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Services', url: '/services/' },
  { name: service.name, url: `/services/${service.slug}/` },
]);

const pageSchema = [
  ...getServicePageSchema(service),
  breadcrumbSchema,
];
const related = getRelatedServices(service.slug);
---

<BaseLayout title={title} description={description} canonical={`/services/${service.slug}/`} schema={pageSchema} image={service.ogImage}>
  <HeroWithLeadForm
    title={`${service.name} in Manchester`}
    description={service.description}
    formId={`service-${service.slug}-lead-form`}
    source={`service:${service.slug}`}
  />

  <section class="section section--tight bg-white">
    <div class="container grid grid--2">
      <article class="card">
        <h2>Common issues we fix</h2>
        <ul>
          <li>Recurring blockages and slow-draining fixtures</li>
          <li>Bad odours and trapped wastewater</li>
          <li>Blocked external drains and gullies</li>
          <li>Emergency overflows and backups</li>
        </ul>
      </article>
      <article class="card">
        <h2>What’s included</h2>
        <ul>
          <li>Initial on-site diagnosis and access checks</li>
          <li>Professional clearance equipment and safety setup</li>
          <li>Transparent explanation of required work</li>
          <li>Aftercare advice and prevention tips</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Our process</h2>
      <div class="grid grid--3">
        <div class="card"><h3>Inspect</h3><p>We assess symptoms and isolate the likely blockage point.</p></div>
        <div class="card"><h3>Resolve</h3><p>We clear and clean drains using the right method for the issue.</p></div>
        <div class="card"><h3>Prevent</h3><p>We provide practical recommendations to reduce repeat callouts.</p></div>
      </div>
    </div>
  </section>

  <section class="section section--tight bg-white">
    <div class="container">
      <h2>Related services</h2>
      <div class="grid grid--3">
        {related.map((item) => (
          <a class="card" href={`/services/${item.slug}/`}>{item.name}</a>
        ))}
      </div>

      <h2 class="mt-10">Popular locations for this service</h2>
      <div class="grid grid--3">
        {LOCATIONS.slice(0, 6).map((location) => (
          <a class="card" href={`/locations/${location.slug}/${service.slug}/`}>{service.name} in {location.name}</a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
